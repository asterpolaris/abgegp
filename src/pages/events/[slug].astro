---
import type { CollectionEntry } from 'astro:content';
import EventGrid from '../../components/EventGrid.astro';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteSettings, getSortedEvents } from '../../lib/site';

export function getStaticPaths() {
	return getSortedEvents().then((events) =>
		events.map((event) => ({
			params: { slug: event.id },
			props: { event }
		}))
	);
}

interface Props {
	event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const [settings, events] = await Promise.all([getSiteSettings(), getSortedEvents()]);
const otherEvents = events.filter((item) => item.id !== event.id);
---

<BaseLayout
	title={`${event.data.title} | ABGE GP`}
	description={event.data.descriptionEn}
	image={event.data.image}
>
	<Navbar
		events={events}
		reservationEmail={settings.reservationEmail}
		dinnerMenuPath={settings.dinnerMenuPath}
		currentEventId={event.id}
	/>
	<main class="bg-black px-4 py-8 sm:px-6">
		<section class="mx-auto grid max-w-[1600px] gap-8 lg:grid-cols-[36rem_minmax(0,1fr)]">
			<div>
				<img src={event.data.image} alt={`${event.data.title} flyer`} class="w-full" />
			</div>

			<div class="flex flex-col gap-6">
				<div>
					<h1 class="nav-face text-5xl font-semibold uppercase tracking-[0.05em] text-white sm:text-6xl">
						{event.data.title}
					</h1>
					<p class="mt-3 text-base uppercase tracking-[0.08em] text-white/80">
						{event.data.dateDisplay} • {event.data.day} • {event.data.time}
					</p>
					<p class="mt-1 text-sm uppercase tracking-[0.08em] text-white/62">{event.data.timeDetail}</p>
					{event.data.category && (
						<p class="mt-3 text-sm uppercase tracking-[0.08em] text-white/80">{event.data.category}</p>
					)}
				</div>

				<div class="space-y-4 text-lg leading-8 text-white/84">
					<p>{event.data.descriptionFr}</p>
					<p>{event.data.descriptionEn}</p>
				</div>

				{event.data.artists.length > 0 && (
					<div>
						<h2 class="nav-face text-2xl uppercase tracking-[0.05em] text-white">Artists / DJs</h2>
						<p class="mt-3 text-base leading-7 text-white/78">{event.data.artists.join(', ')}</p>
					</div>
				)}

				{event.data.specialNotes.length > 0 && (
					<div>
						<h2 class="nav-face text-2xl uppercase tracking-[0.05em] text-white">Event Details</h2>
						<ul class="mt-3 space-y-2 text-base leading-7 text-white/78">
							{event.data.specialNotes.map((note) => <li>{note}</li>)}
						</ul>
					</div>
				)}

				<div class="space-y-2 text-base leading-7 text-white/78">
					<p>{settings.ticketPolicyFr}</p>
					<p>{settings.ticketPolicyEn}</p>
				</div>

				<div class="flex flex-wrap gap-3">
					<a
						href={event.data.ticketUrl || '#'}
						target={event.data.ticketUrl ? '_blank' : undefined}
						rel={event.data.ticketUrl ? 'noreferrer' : undefined}
						class="button-face inline-flex bg-white px-4 py-2 text-[0.95rem] font-semibold uppercase tracking-[0.04em] text-black"
					>
						Buy Tickets
					</a>
					<a
						href={`mailto:${event.data.primaryReservationEmail || settings.reservationEmail}`}
						class="button-face inline-flex border border-white px-4 py-2 text-[0.95rem] font-semibold uppercase tracking-[0.04em] text-white"
					>
						Reservation
					</a>
				</div>
			</div>
		</section>

		{otherEvents.length > 0 && <EventGrid events={otherEvents} mobileScroll={true} />}
	</main>
	<Footer settings={settings} />
</BaseLayout>
