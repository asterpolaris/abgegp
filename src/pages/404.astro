---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Page Not Found | ABGE GP"
	description="The page you requested could not be found."
	image="/images/HERO-BANNER.jpg"
>
	<main class="relative min-h-screen overflow-hidden bg-black">
		<picture class="absolute inset-0 block h-full w-full">
			<img
				src="/images/HERO-BANNER.jpg"
				alt="ABGE GP"
				class="h-full w-full object-cover"
			/>
		</picture>

		<div class="absolute inset-0 bg-black/45"></div>

		<section class="relative z-10 flex min-h-screen items-center justify-center px-6 py-16">
			<div class="flex max-w-2xl flex-col items-center gap-8 text-center">
				<img
					src="/images/logo.png"
					alt="ABGE GP Race Weekend"
					class="h-10 w-auto sm:h-14 md:h-16 lg:h-20"
				/>

				<div class="space-y-4">
					<h1 class="button-face text-4xl font-semibold uppercase tracking-[0.08em] text-white sm:text-5xl">
						Page Not Found
					</h1>
					<p class="text-lg text-white/88">Return to the homepage to continue browsing.</p>
				</div>

				<a
					href="/"
					class="button-face inline-flex border border-white bg-white px-5 py-3 text-lg font-semibold uppercase tracking-[0.05em] text-black"
				>
					Back Home
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
