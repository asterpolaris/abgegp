---
import EventGrid from '../components/EventGrid.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings, getSortedEvents } from '../lib/site';

const [settings, events] = await Promise.all([getSiteSettings(), getSortedEvents()]);
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'ABGE GP',
		url: 'https://abgegp.com/',
		description: settings.description
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'ABGE GP',
		url: 'https://abgegp.com/',
		image: 'https://abgegp.com/images/logo.png'
	}
];
---

<BaseLayout
	title={settings.title}
	description={settings.description}
	image="/images/HERO-BANNER.jpg"
	structuredData={structuredData}
>
	<Navbar
		events={events}
		reservationEmail={settings.reservationEmail}
		dinnerMenuPath={settings.dinnerMenuPath}
	/>
	<main class="bg-black">
		<Hero eyebrow={settings.heroEyebrow} title={settings.heroTitle} />
		<EventGrid events={events} />
	</main>
	<Footer settings={settings} />
</BaseLayout>
