---
import EventGrid from '../components/EventGrid.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings, getSortedEvents } from '../lib/site';

const [settings, events] = await Promise.all([getSiteSettings(), getSortedEvents()]);
---

<BaseLayout title={settings.title} description={settings.description} image={settings.socialImage}>
	<Navbar
		events={events}
		reservationEmail={settings.reservationEmail}
		dinnerMenuPath={settings.dinnerMenuPath}
	/>
	<main>
		<Hero />
		<EventGrid events={events} />
	</main>
	<Footer settings={settings} />
</BaseLayout>
