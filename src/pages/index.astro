---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings } from '../lib/site';

const settings = await getSiteSettings();
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'ABGE GP',
		url: 'https://abgegp.com/',
		description: 'ABGE GP 2026 coming soon.'
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'ABGE GP',
		url: 'https://abgegp.com/',
		image: 'https://abgegp.com/images/logo.png'
	}
];
---

<BaseLayout
	title="ABGE GP 2026 | Coming Soon"
	description="ABGE GP 2026 coming soon."
	image="/images/splash-hero.jpg"
	structuredData={structuredData}
>
	<main class="relative min-h-screen overflow-hidden bg-black">
		<picture class="absolute inset-0 block h-full w-full">
			<source media="(max-width: 767px)" srcset="/images/splash-hero.jpg" />
			<img
				src="/images/splash-hero.jpg"
				alt="ABGE GP 2026 coming soon"
				class="h-full w-full object-cover"
			/>
		</picture>

		<div class="absolute inset-0 bg-black/28"></div>

		<section class="sr-only">
			<h1>ABGE GP 2026 Coming Soon</h1>
			<p>ABGE GP 2026 coming soon.</p>
		</section>

		<section class="relative z-10 flex min-h-screen items-center justify-center px-6 py-16">
			<div class="flex flex-col items-center gap-8 text-center">
				<img
					src="/images/logo.png"
					alt="ABGE GP Race Weekend"
					class="h-10 w-auto sm:h-14 md:h-16 lg:h-20"
				/>

				<p class="button-face text-3xl font-semibold uppercase tracking-[0.08em] text-white sm:text-4xl md:text-5xl">
					2026 Coming Soon
				</p>
			</div>
		</section>
	</main>
</BaseLayout>
