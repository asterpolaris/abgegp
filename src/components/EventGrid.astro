---
import type { CollectionEntry } from 'astro:content';
import EventCard from './EventCard.astro';

interface Props {
	events: CollectionEntry<'events'>[];
	mobileScroll?: boolean;
}

const { events, mobileScroll = false } = Astro.props;
---

<section class="bg-black px-4 py-8 sm:px-6 sm:py-12">
	{
		mobileScroll ? (
			<>
				<div class="mx-auto flex max-w-[1600px] gap-4 overflow-x-auto pb-2 sm:hidden">
					{events.map((event) => (
						<div class="min-w-[84vw] max-w-[84vw] flex-none">
							<EventCard event={event} />
						</div>
					))}
				</div>
				<div class="mx-auto hidden max-w-[1600px] gap-x-6 gap-y-10 sm:grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
					{events.map((event) => <EventCard event={event} />)}
				</div>
			</>
		) : (
			<div class="mx-auto grid max-w-[1600px] gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
				{events.map((event) => <EventCard event={event} />)}
			</div>
		)
	}
</section>
