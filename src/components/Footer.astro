---
import type { CollectionEntry } from 'astro:content';

interface Props {
	settings: CollectionEntry<'settings'>['data'];
}

const { settings } = Astro.props;
---

<footer class="bg-black px-4 pb-10 pt-4 sm:px-6">
	<div class="mx-auto flex max-w-[1600px] flex-col items-center justify-between gap-4 border-t border-white/10 pt-5 sm:flex-row">
		<img src="/images/logo.png" alt="ABGE GP Race Weekend" class="h-6 w-auto opacity-90" />
		<a
			href={settings.builderUrl}
			target="_blank"
			rel="noreferrer"
			class="footer-face text-[0.98rem] text-white/88"
		>
			Built by {settings.builderName}
		</a>
	</div>
</footer>
